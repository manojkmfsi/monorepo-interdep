{
  "name": "@monoreps/app",
  "version": "1.0.0",
  "main": "dist/index.js",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "description": "test",
  "scripts": {
    "build": "wireit",
    "dev": "npm run build && node dist/index.js",
    "test": "node --test **/*.test.js",
    "test:types": "tsc --noEmit"
  },
  "wireit": {
    "build": {
      "command": "tsc",
      "files": [
        "src/**/*.ts",
        "tsconfig.json"
      ],
      "output": ["dist/**"],
      "dependencies": [
        "../form:build",
        "../ui-components:build",
        "../api-client:build",
        "../logger:build",
        "../utils:build"
      ]
    }
  },
  "dependencies": {
    "@monoreps/form": "*",
    "@monoreps/ui-components": "*",
    "@monoreps/api-client": "*",
    "@monoreps/logger": "*",
    "@monoreps/utils": "*"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "typescript": "^5.3.3",
    "wireit": "^0.14.4"
  }
}
