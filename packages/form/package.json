{
  "name": "@monoreps/form",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "private": true,
  "scripts": {
    "build": "wireit",
    "test": "node --test **/*.test.js",
    "test:types": "tsc --noEmit"
  },
  "wireit": {
    "build": {
      "command": "tsc",
      "files": [
        "src/**/*.ts",
        "tsconfig.json"
      ],
      "output": ["dist/**"],
      "dependencies": [
        "../ui-components:build",
        "../api-client:build",
        "../logger:build"
      ]
    }
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "dependencies": {
    "@monoreps/ui-components": "*",
    "@monoreps/api-client": "*",
    "@monoreps/logger": "*"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "typescript": "^5.3.3",
    "wireit": "^0.14.4"
  }
}
