{
  "name": "@monoreps/api-client",
  "version": "1.0.1",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "description": "api-client desc",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "wireit",
    "test": "node --test **/*.test.js",
    "test:types": "tsc --noEmit"
  },
  "wireit": {
    "build": {
      "command": "tsc",
      "files": [
        "src/**/*.ts",
        "tsconfig.json"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": [
        "../logger:build",
        "../utils:build"
      ]
    }
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "dependencies": {
    "@monoreps/logger": "*",
    "@monoreps/utils": "*"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "typescript": "^5.3.3",
    "wireit": "^0.14.4"
  }
}
