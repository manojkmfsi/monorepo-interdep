{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@monoreps/logger": ["packages/logger/dist"],
      "@monoreps/utils": ["packages/utils/dist"],
      "@monoreps/ui-components": ["packages/ui-components/dist"],
      "@monoreps/api-client": ["packages/api-client/dist"],
      "@monoreps/form": ["packages/form/dist"],
      "@monoreps/app": ["packages/app/dist"]
    }
  }
}
