{
  "name": "monorepo-interdep",
  "private": true,
  "version": "1.0.0",
  "description": "A monorepo with 3-level interdependent packages",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:types": "npm run test:types --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "lint": "echo 'No linter configured'",
    "clean": "rm -rf packages/*/dist packages/*/node_modules && npm ci"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "typescript": "^5.3.3",
    "wireit": "^0.14.4"
  }
}
